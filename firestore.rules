rules_version = '2';

// Firestore security rules for the Life Tracker single-file app.
// The app stores each account's data in ONE document: users/{uid}.
// These rules guarantee a signed-in user can read/write ONLY their own
// document — this is what actually enforces per-user data isolation.
// WITHOUT these rules, "test mode" lets any user read everyone's data
// (and after 30 days locks everyone out). Publish these before going live.

service cloud.firestore {
  match /databases/{database}/documents {

    // A user may only touch their own account document.
    // NOTE: request.resource exists only on writes, so the size cap is on
    // `write` only — putting it on `read` would break all reads.
    match /users/{uid} {
      allow read:  if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 1048576;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
